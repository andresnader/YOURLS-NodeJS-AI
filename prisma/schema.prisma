generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Url {
  keyword      String   @id
  url          String
  title        String?
  createdAt    DateTime @default(now())
  ip           String?
  clicks       Int      @default(0)
  redirectType Int      @default(301) // 301 (Permanent) or 302 (Temporary)
  password     String?  // Optional password for the link
  favicon      String?  // [NEW] Stored favicon URL
  isHealthy    Boolean  @default(true) // [NEW] Link health status
  
  userId       String?  // [NEW] Owner of the link
  user         User?    @relation(fields: [userId], references: [id])
  
  logs         Log[]
}

model Log {
  id          Int      @id @default(autoincrement())
  clickedAt   DateTime @default(now())
  shorturl    String
  urlRel      Url      @relation(fields: [shorturl], references: [keyword], onDelete: Cascade)
  referrer    String?
  userAgent   String?
  ipAddress   String?
  countryCode String?
  browser     String?
  os          String?
  device      String?
}

model Option {
  name  String @id
  value String
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         String   @default("USER") // ADMIN or USER
  createdAt    DateTime @default(now())
  urls         Url[]
}

